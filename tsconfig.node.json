{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "tailwind.config.ts",
    "postcss.config.mjs",
    "drizzle.config.ts",
    "src/server/**/*.ts"
  ],
  "exclude": ["src/client", "src/**/*.{ts,tsx}"]
}
